.drink-card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}
.drink-card:active { transform: scale(0.97); }
.drink-image {
  width: 100%;
  height: 220rpx;
}
.drink-info {
  padding: 16rpx;
}
.drink-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.drink-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.drink-bottom {
  margin-top: 12rpx;
}
.drink-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF4D4F;
}
.add-btn-small {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 50%;
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 44rpx;
  text-align: center;
}
.add-btn-small:active { opacity: 0.85; }
