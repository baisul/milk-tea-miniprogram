.location-picker {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  margin: 12px 0;
}

/* 模式切换标签 */
.mode-tabs {
  display: flex;
  gap: 12px;
  margin-bottom: 20px;
  border-bottom: 1px solid #f0f0f0;
  padding-bottom: 12px;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 8px 0;
  font-size: 15px;
  color: #666;
  border-radius: 8px;
  transition: all 0.3s;
  cursor: pointer;
}

.mode-tab.active {
  color: #07c160;
  background: #f0f9f0;
  font-weight: 500;
}

/* 地图选点区域 */
.map-section {
  margin-bottom: 16px;
}

.map-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px;
  background: #07c160;
  color: #fff;
  border-radius: 8px;
  text-align: center;
  font-size: 15px;
  cursor: pointer;
}

.map-btn-icon {
  font-size: 18px;
}

/* 地址展示卡片（地图模式和手动模式共用） */
.address-display {
  margin-top: 16px;
}

.address-card {
  padding: 12px;
  background: #f9f9f9;
  border-radius: 8px;
  border-left: 3px solid #07c160;
}

.address-row {
  margin-bottom: 8px;
  font-size: 13px;
  line-height: 1.5;
  word-break: break-all;
}

.address-row:last-child {
  margin-bottom: 0;
}

.address-label {
  color: #666;
  font-weight: 500;
}

.address-value {
  color: #333;
}

/* 手动选择区域 - 一行三列 */
.region-row {
  display: flex;
  gap: 10px;
  margin-bottom: 16px;
}

.region-item {
  flex: 1;
  min-width: 0; /* 防止内容溢出 */
}

.region-value {
  padding: 10px 8px;
  background: #f5f5f5;
  border-radius: 6px;
  text-align: center;
  font-size: 14px;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 手动输入地址 - 修复显示不全问题 */
.manual-address {
  margin-bottom: 16px;
  width: 100%;
}

.address-input {
  width: 100%;
  padding: 12px;
  background: #f5f5f5;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
  /* 确保输入框可以完整显示 */
  min-height: 44px;
  /* 允许换行 */
  white-space: normal;
  word-wrap: break-word;
  word-break: break-all;
}

/* 如果需要多行显示，可以这样设置 */
.address-input[type="text"] {
  height: auto;
  min-height: 44px;
}

/* 或者使用 textarea 替代 input */
.address-textarea {
  width: 100%;
  padding: 12px;
  background: #f5f5f5;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
  min-height: 80px;
  font-family: inherit;
}
/* 在原有样式基础上添加 */

/* 占位符样式 */
.region-value.placeholder {
  color: #999;
}

/* 输入框标签样式 */
.input-label {
  margin-bottom: 8px;
  font-size: 14px;
  color: #333;
}

.required-star {
  color: #ff4d4f;
  margin-right: 4px;
}

/* textarea 样式 */
.address-textarea {
  width: 100%;
  padding: 12px;
  background: #f5f5f5;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
  min-height: 80px;
  max-height: 150px;
  line-height: 1.5;
  font-family: inherit;
}

.placeholder-class {
  color: #ccc;
  font-size: 14px;
}