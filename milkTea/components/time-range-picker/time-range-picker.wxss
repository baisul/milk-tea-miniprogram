/* components/time-range-picker/time-range-picker.wxss */
.time-range-picker {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.field-label {
  font-size: 28rpx;
  color: #666666;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.row-label {
  width: 96rpx;
  font-size: 28rpx;
  color: #666666;
}

.row-picker {
  flex: 1;
}

.row-value {
  height: 88rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333333;
}

.label {
  display: flex;
  flex-direction: row;
  align-items: center;  /* 垂直居中 */
  justify-content: flex-start;  /* 水平靠左 */
}

.required-star {
  color: #ff4d4f;
  font-size: 28rpx;
  line-height: 1;  /* 确保垂直居中 */
  margin-right: 8rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1;
}


