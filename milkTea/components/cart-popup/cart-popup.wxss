/* components/cart-popup/cart-popup.wxss */
.cart-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.cart-popup-mask.show {
  visibility: visible;
  opacity: 1;
}

.cart-popup {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 80vh;
}

.cart-popup.slide-up {
  transform: translateY(0);
}

/* 顶部操作栏 */
.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  background-color: #f8f8f8;
  border-radius: 32rpx 32rpx 0 0;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  background-color: #ffffff;
}

.checkbox.checked {
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-color: #FF7A2E;
}

.checkbox-icon {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}

.select-all-text {
  font-size: 28rpx;
  color: #333333;
}

.clear-btn {
  font-size: 28rpx;
  color: #999999;
  padding: 8rpx 16rpx;
}

.clear-btn:active {
  opacity: 0.6;
}

/* 滚动区域 */
.popup-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx;
  max-height: 50vh;
}

/* 加载动画 */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background-color: #FF7A2E;
  border-radius: 50%;
  animation: loading-dot 1.2s ease-in-out infinite;
}

.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes loading-dot {
  0%, 60%, 100% {
    transform: scale(0.8);
    opacity: 0.5;
  }
  30% {
    transform: scale(1.2);
    opacity: 1;
  }
}

/* 空状态 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 购物车列表 */
.cart-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 20rpx 0;
}

.cart-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;  /* 关键：确保占满父容器宽度 */
}

/* 复选框 */
.cart-checkbox {
  flex-shrink: 0;
}

/* 商品图片 */
.cart-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  object-fit: cover;
  flex-shrink: 0;
}

/* 商品信息 */
.cart-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;  /* 允许内容收缩，防止溢出 */
  overflow: hidden;
}

.cart-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-spec {
  display: inline-flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #f8f9fa, #f0f2f5);
  border-radius: 40rpx;
  border: 1rpx solid #e0e4e8;
  font-size: 22rpx;
  color: #555555;
  align-self: flex-start;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  max-width: 100%;
}

.cart-price {
  font-size: 26rpx;
  font-weight: bold;
  color: #FF7A2E;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 20rpx;
  color: #999999;
  font-size: 24rpx;
}

/* 底部结算栏 - 保持黑色背景 */
.popup-footer {
  display: flex;
  align-items: center;
  background-color: #2c2c2c;  /* 保持黑色背景 */
  border-radius: 60rpx;
  margin: 20rpx 24rpx;
  padding: 12rpx 16rpx;
  gap: 16rpx;
  flex-shrink: 0;
}

/* 购物车图标容器 */
.cart-icon-wrap {
  position: relative;
  flex-shrink: 0;
}

/* 购物车图片 - 添加白色背景和填充 */
.cart-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 50%;
  padding: 16rpx;  /* 内边距，让图标看起来更舒适 */
  box-sizing: border-box;
}

/* 商品规格 - 胶囊样式 */
.cart-spec {
  display: inline-flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #f8f9fa, #f0f2f5);
  border-radius: 40rpx;
  border: 1rpx solid #e0e4e8;
  font-size: 24rpx;
  color: #555555;
  align-self: flex-start;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}

.cart-spec .edit-icon {
  font-size: 22rpx;
  color: #FF7A2E;
  margin-left: 12rpx;
  font-weight: 600;
  opacity: 0.8;
}

/* 点击态 */
.cart-spec:active {
  background: linear-gradient(135deg, #e8eef0, #e0e5e8);
  transform: scale(0.97);
  border-color: #d0d5d8;
}
/* 数量控制 - 带长方形边框和分割线 */
.cart-quantity {
  flex-shrink: 0; 
  display: flex;
  margin-left: auto;
  justify-content: flex-end;
}

/* 数量包装器 - 居右显示 */
.quantity-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;  /* 居右 */
  width: 100%;
  padding-right: 70rpx;  /* 这会生效 */
}

/* 数量控制器 - 长方形边框 */
.quantity-control {
  display: flex;
  align-items: center;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  background-color: #ffffff;
  overflow: hidden;
  height: 60rpx;  /* 统一高度 */
  width: 180rpx;  /* 固定宽度 */
}
/* 减号按钮 - 灰色样式 */
.qty-btn.minus {
  width: 60rpx;  /* 与加号宽度一致 */
  height: 60rpx;  /* 与容器高度一致 */
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  transition: all 0.2s ease;
}

.qty-btn.minus .qty-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #999999;
  line-height: 1;
}

/* 加号按钮 - 褐色样式 */
.qty-btn.plus {
  width: 60rpx;  /* 与减号宽度一致 */
  height: 60rpx;  /* 与容器高度一致 */
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  background-color: #ffffff;
}

.qty-btn.plus .qty-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF7A2E;
}

/* 按钮点击效果 */
.qty-btn.minus:active {
  background-color: #e0e0e0;
  transform: scale(0.95);
}

.qty-btn.plus:active {
  opacity: 0.9;
  transform: scale(0.95);
}

/* 竖线分隔符 */
.qty-divider {
  width: 1rpx;
  height: 100%;  /* 占满父容器高度 */
  background-color: #e0e0e0;
  flex-shrink: 0;
}

/* 数量数字 */
.qty-num {
  min-width: 46rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0 4rpx;
}

.cart-emoji {
  font-size: 44rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background-color: #FF4D4F;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 24rpx;
  min-width: 32rpx;
  text-align: center;
}

/* 价格信息 */
.price-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.total-price,
.delivery-fee {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price-label,
.fee-label {
  font-size: 24rpx;
  color: #cccccc;
}

.price-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.fee-value {
  font-size: 24rpx;
  color: #ffffff;
}

/* 结算按钮 - 保持橙色 */
.checkout-btn {
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  flex-shrink: 0;
}

.checkout-btn text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

.checkout-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}