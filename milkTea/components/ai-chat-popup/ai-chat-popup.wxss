/* 遮罩层 - 默认隐藏 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

/* 遮罩层 - 显示状态 */
.popup-mask.show {
  opacity: 1;
  visibility: visible;
}

/* 弹窗容器 - 使用calc动态计算 */
.popup-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 85%;  /* 从80%增加到85% */
  max-height: 75%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  padding-bottom: env(safe-area-inset-bottom);  /* 适配底部安全区域 */
}

/* 弹窗容器 - 显示状态 */
.popup-container.show {
  transform: translateY(0);
}

/* 头部 */
.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 32rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.popup-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 32rpx;
  color: #999;
}

.popup-close:active {
  background: #e5e5e5;
}

/* 内容区域 - 确保有足够空间 */
.popup-content {
  flex: 1;
  overflow: hidden;
  position: relative;
  min-height: 0;
  width: 100%;
}

/* 确保ai-chat组件填满并可以滚动 */
.popup-content > ai-chat {
  display: block;
  width: 100%;
  height: 100%;
  overflow: hidden;
}