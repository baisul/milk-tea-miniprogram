/* 容器 */
.chat-container {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #f5f7fb;
  overflow: hidden;
}

/* 消息区域 */
.message-area {
  flex: 1;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  overflow-y: auto;
  padding-bottom: 0;
}

/* 底部区域 */
.bottom-area {
  background: white;
  border-top: 1rpx solid #eee;
  flex-shrink: 0;
  padding-bottom: 0;
}

/* 工具栏 - 加大内边距 */
.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #ffffff;
}

/* 模型选择器 - 调大 */
.model-selector {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 24rpx;
  background: #f5f7fb;
  border-radius: 48rpx;
  border: 1rpx solid #e8e8e8;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.02);
}

.model-selector:active {
  background: #e8e8e8;
  transform: scale(0.96);
}

.model-icon {
  font-size: 28rpx;
}

.model-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF7A2E;
}

.model-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 工具栏右侧按钮组 - 加大间距 */
.toolbar-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* 置顶/置底按钮 - 调大 */
.tool-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background: #f5f7fb;
  border-radius: 50%;
  border: 1rpx solid #e8e8e8;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.02);
  transition: all 0.2s ease;
}

.tool-btn:active {
  background: #e8e8e8;
  transform: scale(0.94);
}

.tool-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 清空聊天按钮 - 调大 */
.clear-chat-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #f5f7fb;
  border-radius: 48rpx;
  border: 1rpx solid #e8e8e8;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.02);
}

.clear-chat-btn:active {
  background: #e8e8e8;
  transform: scale(0.96);
}

.clear-chat-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
}

/* 输入框行 */
.input-wrapper {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  padding-bottom: 0;
}

/* 输入框 */
.input-box {
  flex: 1;
  min-height: 72rpx;
  max-height: 140rpx;
  background: #f8f9fc;
  border: 1.5rpx solid #e0e4e8;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  overflow-y: auto;
}

.input-box:focus {
  border-color: #FF7A2E;
  background: white;
  box-shadow: 0 0 0 4rpx rgba(255, 122, 46, 0.08);
}

.placeholder {
  color: #bbb;
  font-size: 28rpx;
}

/* 操作按钮（清空输入框/发送） */
.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background: #f5f7fb;
  border-radius: 50%;
  flex-shrink: 0;
  border: 1rpx solid #e8e8e8;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.94);
  background: #e8e8e8;
}

.btn-image {
  width: 38rpx;
  height: 38rpx;
}

/* 发送按钮 - 激活状态 */
.send-btn.active {
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 122, 46, 0.3);
}

.send-btn.active .btn-image {
  filter: brightness(0) invert(1);
}

/* 消息气泡样式 */
.message-item {
  margin-bottom: 20rpx;
  display: flex;
  width: 100%;
}

.message-item.user {
  justify-content: flex-end;
}

.message-item.assistant {
  justify-content: flex-start;
}

.message-bubble {
  max-width: 75%;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.user .message-bubble {
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  color: white;
  border-radius: 28rpx 8rpx 28rpx 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 122, 46, 0.2);
}

.assistant .message-bubble {
  background: white;
  color: #333;
  border-radius: 8rpx 28rpx 28rpx 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #f0f0f0;
}

.typing {
  background: #f0f0f0;
  color: #999;
}