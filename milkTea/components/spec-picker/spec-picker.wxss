/* components/spec-picker/spec-picker.wxss */

.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.picker-panel {
  width: 100%;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  position: relative;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.slide-up {
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

/* 顶部关闭按钮 - 白色背景带阴影 */
.picker-close-wrap {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  z-index: 10;
}

.picker-close {
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(0, 0, 0, 0.3);  /* 半透明黑色背景 */
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  transition: all 0.2s ease;
}

.picker-close:active {
  transform: scale(0.94);
  opacity: 0.8;
}

/* 滚动内容区域 */
.picker-body {
  flex: 1;
  overflow-y: auto;
  padding: 40rpx 32rpx 20rpx;
}

/* 商品图片区域 - 占满宽度 */
.drink-image-wrap {
  width: 100%;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.drink-img {
  width: 100%;
  height: auto;
  display: block;
  /* mode="widthFix" 会让高度自动按比例缩放 */
}

/* 商品名称 */
.drink-name {
  display: block;
  text-align: left;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

/* 商品描述 */
.drink-desc {
  display: block;
  text-align: left;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

/* 规格区域 */
.spec-section {
  margin-bottom: 28rpx;
}

.spec-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.spec-item {
  padding: 16rpx 28rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666666;
  border: 1rpx solid transparent;
  transition: all 0.2s ease;
}

.spec-item.active {
    background: #E8F5E9;
    color: #2E7D32;
    border: 1rpx solid #4CAF50;
}

.spec-extra {
  font-size: 22rpx;
  margin-left: 4rpx;
}

.picker-footer {
  display: flex;
  justify-content: space-between;
  align-items: stretch;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.08);
  border-top: 1rpx solid #f0f0f0;
  gap: 24rpx;
}

/* 左侧：立即购买区域 */
.buy-now-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  /* 移除 border-right, margin-right, padding-right, align-items */
}

/* 小计包装器 - 居左显示 */
.subtotal-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  justify-content: flex-start;
  width: 100%;
}

.subtotal-label {
  font-size: 22rpx;
  color: #999999;
}

.subtotal-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF7A2E;
}

/* 立即购买按钮 */
.buy-now-btn {
  width: 100%;
  padding: 20rpx 0;
  background-color: #ffffff;
  border: 2rpx solid #FF7A2E;
  border-radius: 50rpx;
  color: #FF7A2E;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  box-sizing: border-box;
  margin-top: auto;
}

.buy-now-btn:active {
  background-color: #FFF5EE;
  transform: scale(0.96);
}

/* 右侧：加入购物车区域 */
.add-cart-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 数量包装器 - 居右显示 */
.quantity-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;  /* 居右 */
  gap: 16rpx;
}

/* 数量控制器 - 长方形边框 */
.quantity-control {
  display: flex;
  align-items: stretch;  /* 让子元素高度撑满 */
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  background-color: #ffffff;
  overflow: hidden;
  height: 64rpx;  /* 添加固定高度 */
}

/* 减号按钮 - 灰色样式 */
.qty-btn.minus {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  transition: all 0.2s ease;
}

.qty-btn.minus .qty-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #999999;
}

/* 加号按钮 - 褐色样式 */
.qty-btn.plus {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  background-color: #ffffff;
}

.qty-btn.plus .qty-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF7A2E;
}

/* 按钮点击效果 */
.qty-btn.minus:active {
  background-color: #e0e0e0;
  transform: scale(0.95);
}

.qty-btn.plus:active {
  opacity: 0.9;
  transform: scale(0.95);
}

/* 竖线分隔符 */
.qty-divider {
  width: 1rpx;
  height: 100%;  /* 占满父容器高度 */
  background-color: #e0e0e0;
  flex-shrink: 0;
}

/* 数量数字 */
.qty-num {
  font-size: 30rpx;
  font-weight: 500;
  min-width: 52rpx;
  text-align: center;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 加入购物车按钮 */
.add-cart-btn {
  width: 100%;
  padding: 20rpx 0;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  box-sizing: border-box;
  margin-top: auto;
}

.add-cart-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 编辑模式样式（如果有需要） */
.picker-footer-edit {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.08);
  border-top: 1rpx solid #f0f0f0;
}

.edit-confirm-btn {
  width: 100%;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}
/* 编辑模式底部栏 */
.picker-footer-edit {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.08);
  border-top: 1rpx solid #f0f0f0;
}

/* 确认修改按钮 - 占满宽度，高度与立即购买按钮一致 */
.edit-confirm-btn {
  width: 100%;
  padding: 20rpx 0;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  box-sizing: border-box;
}

.edit-confirm-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}