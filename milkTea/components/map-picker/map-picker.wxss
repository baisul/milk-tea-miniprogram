/* components/map-picker/map-picker.wxss */
.map-picker {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.field-label {
  font-size: 28rpx;
  color: #666666;
}

.map-preview {
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
}

.map-preview-text {
  font-size: 26rpx;
  color: #333333;
  word-break: break-all;
}

.map-actions {
  display: flex;
}

.map-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  background: #ffffff;
  border: 1rpx solid #eeeeee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--primary);
}

.map-btn:active {
  opacity: 0.85;
}

