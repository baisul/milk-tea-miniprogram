.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.dialog-box {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.dialog-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}
.dialog-content {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}
.dialog-buttons {
  width: 100%;
  display: flex;
  border-top: 1rpx solid #eee;
}
.dialog-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}
.dialog-btn-cancel {
  color: #999;
  border-right: 1rpx solid #eee;
}
.dialog-btn-cancel:active { background: #f5f5f5; }
.dialog-btn-confirm {
  font-weight: 500;
}
.dialog-btn-confirm:active { background: #f5f5f5; }
.dialog-btn-confirm.danger { color: #FF4D4F; }
.scale-in {
  animation: scaleIn 0.2s ease-out;
}
@keyframes scaleIn {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
