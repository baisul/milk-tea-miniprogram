/* components/nav-bar/nav-bar.wxss */

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background-color: #F7F8FA;
  /* 确保内容在安全区域内 */
  box-sizing: border-box;
}

.nav-bar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  position: relative;
  box-sizing: border-box;
  /* 高度在 JS 中动态设置，单位为 px */
}

/* 左侧区域 */
.nav-left {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
}

/* 返回按钮 */
.back-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s;
}

.back-btn-hover {
  opacity: 0.6;
  background-color: rgba(0, 0, 0, 0.05);
}

.back-icon-img {
  width: 22px;
  height: 22px;
}

/* 中间标题区域 */
.nav-center {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10px;
}

.nav-title {
  font-size: 17px;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 200px;
}

/* 右侧区域 */
.nav-right {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
}

/* 占位视图 */
.nav-placeholder {
  width: 100%;
  background-color: transparent;
}