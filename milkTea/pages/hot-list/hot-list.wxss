/* pages/hot-list/hot-list.wxss */
.hot-list-page {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 40rpx;
}

/* 导航栏 */
.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-top: calc(92rpx + env(safe-area-inset-top));
  background: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid #F0F0F0;
}

.nav-back {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 40rpx;
}

.back-icon {
  font-size: 32rpx;
  color: #666;
}

.back-text {
  font-size: 28rpx;
  color: #666;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.nav-placeholder {
  width: 120rpx;
}

/* 热门列表 */
.hot-list {
  padding: 20rpx 24rpx;
}

.hot-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.hot-card:active {
  transform: scale(0.98);
}

.hot-rank {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-right: 20rpx;
  flex-shrink: 0;
}

/* 排名1-3特殊样式 */
.hot-card:first-child .hot-rank {
  background: linear-gradient(135deg, #FFD700, #FFA500);
}
.hot-card:nth-child(2) .hot-rank {
  background: linear-gradient(135deg, #C0C0C0, #A0A0A0);
}
.hot-card:nth-child(3) .hot-rank {
  background: linear-gradient(135deg, #CD7F32, #B87333);
}

.hot-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.hot-info {
  flex: 1;
  min-width: 0;
}

.hot-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF7A2E;
  display: block;
  margin-bottom: 8rpx;
}

.hot-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-action {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.order-btn {
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.order-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #999;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  background: #FF7A2E;
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite both;
}

.loading-dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.3); opacity: 0.3; }
  40% { transform: scale(1); opacity: 1; }
}

/* 动画 */
.fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}