/* pages/menu/menu.wxss - 分类点单页样式 */

.menu-page {
  min-height: 100vh;
  background: var(--bg-color, #F7F8FA);
  display: flex;
  flex-direction: column;
}

/* 顶部导航栏 */
.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  position: sticky;
  top: 0;
  z-index: 100;
}

/* 返回按钮 */
.nav-back {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  transition: all 0.2s;
}

.nav-back:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

.back-btn {
  position: absolute; right: 32rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  font-size: 24rpx; color: #FFFFFF; padding: 8rpx 16rpx;
  border-radius: 20rpx;
}
.back-btn:active { background: #EEE; }

/* 店铺名称（居中） */
.shop-name {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 20rpx;
}
/* 主体区域 */
.menu-body {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧分类栏 */
.category-sidebar {
  width: 180rpx;
  height: calc(100vh - 200rpx);
  background: #F0F0F0;
}

/* 分类项 - 纵向排列，文字横向显示 */
.category-item {
  padding: 28rpx 16rpx;
  text-align: center;
  position: relative;
  transition: all 0.2s;
  display: block;
}

.category-item.active {
  background: #FFFFFF;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 48rpx;
  background: #FF7A2E;
  border-radius: 0 6rpx 6rpx 0;
}

.category-name {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  display: inline-block;
  text-align: center;
  white-space: nowrap;
}

.category-item.active .category-name {
  color: #FF7A2E;
  font-weight: 600;
}


.category-count {
  font-size: 18rpx;
  color: #999999;
  margin-top: 4rpx;
}

.category-item.active .category-count {
  color: #FF7A2E;
}

/* 右侧饮品列表 */
.drink-list {
  flex: 1;
  height: calc(100vh - 200rpx);
  padding: 16rpx 20rpx;
}

/* 加载 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background: #FF7A2E;
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite both;
}

.loading-dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dot:nth-child(2) { animation-delay: -0.16s; }
.loading-dot:nth-child(3) { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.3); opacity: 0.3; }
  40% { transform: scale(1); opacity: 1; }
}

/* 饮品项 */
.drink-items {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.drink-item {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.drink-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.drink-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.drink-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.drink-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-word;
  line-height: 1.4;
  max-height: 68rpx;
  transition: all 0.2s;
}

.drink-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.drink-price {
  font-size: 34rpx;
  font-weight: 600;
  color: #FF4D4F;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 500;
}

.drink-stock {
  font-size: 20rpx;
  color: #FF7A2E;
  background: #FFF5ED;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 12rpx;
}

.drink-stock.sold-out {
  color: #999999;
  background: #F7F8FA;
}

.add-btn {
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 52rpx;
  text-align: center;
  flex-shrink: 0;
}

.add-btn:active {
  opacity: 0.85;
}

.add-btn.disabled {
  background: #DDDDDD;
}

/* 动画 */
.fade-in {
  animation: fadeIn 0.3s ease-out both;
}

.fade-in:nth-child(2) { animation-delay: 0.05s; }
.fade-in:nth-child(3) { animation-delay: 0.1s; }
.fade-in:nth-child(4) { animation-delay: 0.15s; }
.fade-in:nth-child(5) { animation-delay: 0.2s; }

@keyframes fadeIn {
  from { opacity: 0; transform: translateX(20rpx); }
  to { opacity: 1; transform: translateX(0); }
}