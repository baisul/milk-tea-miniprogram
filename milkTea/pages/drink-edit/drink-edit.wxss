/* pages/drink-edit/drink-edit.wxss - 饮品编辑页样式 */

.drink-edit-page {
  min-height: 100vh;
  background: var(--bg-color, #F7F8FA);
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* ============ 表单分区 ============ */
.form-section {
  background: #FFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

/* ============ 图片上传 ============ */
.image-upload {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F7F8FA;
}

.upload-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #DDD;
  border-radius: 16rpx;
}

.upload-icon {
  font-size: 56rpx;
  color: #CCC;
  line-height: 1;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 22rpx;
  color: #CCC;
}

.upload-loading {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 48rpx;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #FFF;
}

/* ============ 表单项 ============ */
.form-item {
  margin-bottom: 24rpx;
  position: relative;
}

.form-item:last-child { margin-bottom: 0; }

.form-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.form-required {
  font-size: 26rpx;
  color: #FF4D4F;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.6;
}

/* ============ 规格选择 ============ */
/* ============ 规格选择 ============ */
.spec-group {
  margin-bottom: 28rpx;
}

.spec-group:last-child { margin-bottom: 0; }

.spec-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.spec-count {
  font-size: 22rpx;
  color: #999;
  margin-left: 8rpx;
}

.spec-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.spec-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 28rpx;
  background: #F7F8FA;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s ease;
  cursor: pointer;
}

/* 点击反馈 */
.spec-tag:active {
  transform: scale(0.96);
  opacity: 0.8;
}

.spec-check {
  font-size: 24rpx;
  font-weight: 700;
}
/* ============ 上架状态 ============ */
.shelf-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.shelf-label {
  font-size: 28rpx;
  color: #333;
}

.shelf-hint {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 12rpx;
}

/* ============ 底部按钮 ============ */
.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFF;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.save-btn {
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #FFF;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  box-shadow: 0 4rpx 16rpx rgba(255,122,46,0.35);
}

.save-btn:active { opacity: 0.85; }
.save-btn.disabled { opacity: 0.5; }
/* pages/drink-edit/drink-edit.wxss */

/* 杯型标签包装器 - 每个杯型占一行或内联块 */
.spec-tag-wrapper {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  margin-right: 20rpx;
  margin-bottom: 16rpx;
  background: #F8F8FA;
  border-radius: 48rpx;
  padding-right: 16rpx;
}

/* 规格标签 */
.spec-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 48rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
  cursor: pointer;
}

.spec-tag.active {
  background: #E8F5E9;
  color: #2E7D32;
  border: 1rpx solid #4CAF50;
}

/* 加价输入框 */
.extra-price-input {
  display: inline-flex;
  align-items: center;
  background: #FFFFFF;
  border: 1rpx solid #E5E5E5;
  border-radius: 32rpx;
  padding: 0 12rpx;
  height: 56rpx;
  margin-right: 8rpx;
}

.extra-label {
  font-size: 24rpx;
  color: #FF7A2E;
  font-weight: 500;
  margin-right: 4rpx;
}

.extra-input {
  width: 80rpx;
  font-size: 26rpx;
  color: #333;
  text-align: center;
  background: transparent;
}

.extra-input[disabled] {
  color: #CCC;
  opacity: 0.6;
}

/* 或者让未选中的杯型不显示加价输入框 */
.extra-price-input.hidden {
  display: none;
}
