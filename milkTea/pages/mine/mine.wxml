<!--pages/mine/mine.wxml - 我的Tab页-->
<view class="mine-page">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-card-bg"></view>
    <view class="user-info-section">
      <view class="avatar-wrap avatar-with-edit" wx:if="{{hasUserInfo && userInfo.avatarUrl}}" bindtap="onUserInfoClick">
        <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
        <view class="avatar-edit-icon">📷</view>
      </view>
      <view class="avatar-wrap avatar-default" wx:else bindtap="onUserInfoClick">
        <text class="avatar-text">👤</text>
      </view>
      <view class="user-text" bindtap="onUserInfoClick">
        <text class="user-name" wx:if="{{isRegistered && userInfo.nickname}}">{{userInfo.nickname}}</text>
        <text class="user-name" wx:else>未注册</text>
        <text class="user-desc" wx:if="{{isRegistered && userInfo.nickname}}">欢迎回来，今天想喝什么呢？</text>
        <text class="user-desc" wx:else>点击头像登录/注册</text>
      </view>
    </view>

    <!-- 快捷统计 - 添加点击事件 -->
    <view class="stats-row">
      <view class="stat-item" bindtap="onAddressClick">
        <text class="stat-num">{{addressCount}}</text>
        <text class="stat-label">地址</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onOrderClick">
        <text class="stat-num">{{orderStats.total}}</text>
        <text class="stat-label">订单</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onPendingClick">
        <text class="stat-num">{{orderStats.pending}}</text>
        <text class="stat-label">待处理</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onCompletedClick">
        <text class="stat-num">{{orderStats.completed}}</text>
        <text class="stat-label">已完成</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单列表 -->
  <view class="menu-section">
    <text class="menu-section-title">管理功能</text>
    <view class="menu-card">
      <view class="menu-item fade-in" wx:for="{{menuItems}}" wx:key="id" data-url="{{item.url}}" bindtap="onMenuTap">
        <view class="menu-icon-wrap">
          <image class="menu-icon" src="{{item.icon}}" mode="aspectFit" />
        </view>
        <view class="menu-info">
          <text class="menu-title">{{item.title}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 活动推荐卡片 -->
  <view class="promo-section">
    <view class="promo-card fade-in">
      <view class="promo-left">
        <text class="promo-badge">会员专属</text>
        <text class="promo-title">生日月享8折优惠</text>
        <text class="promo-desc">完善个人信息，生日当天享受折扣</text>
      </view>
      <text class="promo-emoji">🎂</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">奶茶点单 v1.0.0</text>
  </view>

  <!-- 底部留白 -->
  <view class="page-bottom-space"></view>
</view>