/* pages/address-edit/address-edit.wxss - 地址编辑页样式 */

.address-edit-page {
  min-height: 100vh;
  background: var(--bg-color, #F7F8FA);
  padding: 24rpx 32rpx;
}

/* ============ 表单分区 ============ */
.form-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary, #333);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.section-label::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 28rpx;
  background: #FF7A2E;
  border-radius: 3rpx;
  margin-right: 12rpx;
}

/* ============ 输入框 ============ */
.form-group {
  margin-bottom: 0;
}

.form-group-sm {
  margin-top: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-color, #F7F8FA);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: var(--text-primary, #333);
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.form-input:focus {
  background: #FFFFFF;
  border: 2rpx solid #FF7A2E;
  box-shadow: 0 0 0 4rpx rgba(255, 122, 46, 0.1);
}

/* ============ 性别选择 ============ */
.gender-row {
  display: flex;
  gap: 24rpx;
}

.gender-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  background: var(--bg-color, #F7F8FA);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.gender-item.active {
  background: #FFF5ED;
  border-color: #FF7A2E;
}

.gender-item:active {
  opacity: 0.8;
}

.gender-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #DDD;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #FFFFFF;
  transition: all 0.2s;
}

.gender-item.active .gender-check {
  background: #FF7A2E;
  border-color: #FF7A2E;
}

.gender-text {
  font-size: 28rpx;
  color: var(--text-primary, #333);
}

/* ============ 地图选点 ============ */
.map-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background: var(--bg-color, #F7F8FA);
  border-radius: 16rpx;
  padding: 0 28rpx;
  transition: background 0.2s;
}

.map-btn:active {
  background: #F0F0F0;
}

.map-btn-left {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.map-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.map-btn-text {
  font-size: 28rpx;
  color: var(--text-primary, #333);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map-btn-placeholder {
  font-size: 28rpx;
  color: var(--text-placeholder, #CCC);
}

.map-arrow {
  font-size: 36rpx;
  color: var(--text-placeholder, #CCC);
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ============ 标签选择 ============ */
.tag-row {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.tag-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-regular, #666);
  background: var(--bg-color, #F7F8FA);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.tag-item:active {
  opacity: 0.8;
}

.tag-item.home.active {
  background: #E8F5E9;
  color: #4CAF50;
  border-color: #4CAF50;
}

.tag-item.company.active {
  background: #FFF5ED;
  color: #FF7A2E;
  border-color: #FF7A2E;
}

.tag-item.school.active {
  background: #E3F2FD;
  color: #2196F3;
  border-color: #2196F3;
}

.tag-item.other.active {
  background: #F5F5F5;
  color: #666;
  border-color: #999;
}

/* ============ 保存按钮 ============ */
.save-section {
  margin-top: 40rpx;
  padding: 0 8rpx;
}

.save-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  box-shadow: 0 6rpx 20rpx rgba(255, 122, 46, 0.35);
  transition: opacity 0.2s, transform 0.2s;
}

.save-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.save-btn.disabled {
  opacity: 0.5;
}
