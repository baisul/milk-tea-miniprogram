/* pages/hot-drink-manage/hot-drink-manage.wxss - 热门饮品维护页样式 */
.hot-drink-page {
  min-height: 100vh;
  background: #F7F8FA;
}

/* ===== 提示说明 ===== */
.tip-section {
  margin: 20rpx 30rpx;
  padding: 24rpx;
  background: #FFF9F0;
  border-radius: 12rpx;
  border-left: 4rpx solid #FF7A2E;
}

.tip-text {
  font-size: 24rpx;
  color: #FF7A2E;
  line-height: 1.6;
}

/* ===== 加载中 ===== */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background: #FF7A2E;
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.8); opacity: 0.5; }
  40% { transform: scale(1.2); opacity: 1; }
}

/* ===== 热门饮品列表 ===== */
.hot-list {
  padding: 20rpx 30rpx;
}

.hot-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.hot-main {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.hot-rank {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF7A2E, #FF9A56);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.hot-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  background: #F0F0F0;
  flex-shrink: 0;
}

.hot-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.hot-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF7A2E;
  margin-bottom: 12rpx;
}

.hot-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.hot-sort-label {
  font-size: 24rpx;
  color: #999999;
}

.hot-sort {
  font-size: 24rpx;
  font-weight: 600;
  color: #FF7A2E;
}

/* ===== 操作按钮 ===== */
.hot-actions {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 16rpx;
  background: #FAFAFA;
}

.action-btn {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666666;
  gap: 8rpx;
  transition: all 0.2s;
}

.action-btn:active {
  background: #F0F0F0;
}

.action-icon {
  font-size: 28rpx;
}

.action-btn-danger {
  color: #FF4D4F;
}

.action-btn-danger:active {
  background: #FFF1F0;
}

/* ===== 底部按钮 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #F0F0F0;
  z-index: 10;
}

.add-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF7A2E, #FF9A56);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 122, 46, 0.3);
}

.add-btn:active {
  transform: scale(0.98);
}

/* ===== 弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.modal-panel {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  overflow: hidden;
}

.slide-up {
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 36rpx;
  color: #999999;
  padding: 8rpx;
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #BBBBBB;
}

.picker-active {
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

.form-value {
  display: block;
  font-size: 28rpx;
  color: #333333;
  padding: 0 24rpx;
}

.form-input-wrap {
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
  color: #333333;
}

.modal-footer {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border-radius: 12rpx;
}

.modal-btn-cancel {
  background: #F7F8FA;
  color: #666666;
}

.modal-btn-cancel:active {
  background: #F0F0F0;
}

.modal-btn-confirm {
  background: linear-gradient(135deg, #FF7A2E, #FF9A56);
  color: #ffffff;
}

.modal-btn-confirm:active {
  opacity: 0.9;
}

/* ===== 选择器 ===== */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.picker-panel {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
  flex-shrink: 0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.picker-close {
  font-size: 36rpx;
  color: #999999;
  padding: 8rpx;
}

.picker-search {
  padding: 20rpx 30rpx;
  background: #F7F8FA;
  flex-shrink: 0;
}

.picker-search-input {
  width: 100%;
  height: 72rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 0 60rpx 0 24rpx;
  font-size: 28rpx;
  position: relative;
}

.picker-search-icon {
  position: absolute;
  right: 50rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #BBBBBB;
}

.picker-list {
  flex: 1;
  overflow-y: auto;
}

.picker-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: #BBBBBB;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
  transition: background 0.2s;
}

.picker-item:active {
  background: #F7F8FA;
}

.picker-item.active {
  background: #FFF5EE;
}

.picker-item-name {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.picker-item-price {
  font-size: 26rpx;
  color: #FF7A2E;
  margin-right: 16rpx;
}

.picker-check {
  font-size: 32rpx;
  color: #FF7A2E;
  font-weight: 600;
}

/* ===== 底部留白 ===== */
.page-bottom-space {
  height: 180rpx;
}
.form-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  line-height: 1.4;
}