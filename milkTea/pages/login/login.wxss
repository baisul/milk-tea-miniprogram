/* pages/login/login.wxss - 授权注册页样式 */
.login-page {
  min-height: 100vh;
  background: #FFF5EE;
  position: relative;
  overflow: hidden;
}

/* ===== 顶部装饰区 ===== */
.header-section {
  position: relative;
  height: 420rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 340rpx;
  background: linear-gradient(135deg, #FF7A2E 0%, #FF9A56 60%, #FFB876 100%);
  border-radius: 0 0 50% 50% / 0 0 60rpx 60rpx;
}

.header-wave {
  position: absolute;
  bottom: 0;
  left: -10%;
  width: 120%;
  height: 120rpx;
  background: #FFF5EE;
  border-radius: 50% 50% 0 0;
}

.header-content {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  z-index: 2;
}

.logo-wrap {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 122, 46, 0.3);
}

.logo-emoji {
  font-size: 64rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

/* ===== 表单卡片 ===== */
.form-card {
  margin: -20rpx 60rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 122, 46, 0.12);
}

.form-item {
  display: flex;
  align-items: center;
  height: 110rpx;
}

.form-icon {
  width: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.iconfont {
  font-size: 40rpx;
}

.form-input-wrap {
  flex: 1;
  height: 100%;
  display: flex;
  align-items: center;
}

.form-input {
  width: 100%;
  height: 100%;
  font-size: 30rpx;
  color: #333333;
}

.form-picker {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-placeholder {
  font-size: 30rpx;
  color: #bbb;
}

.picker-active {
  font-size: 30rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-right: 8rpx;
}

.form-divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 0 20rpx;
}

/* ===== 注册按钮 ===== */
.btn-section {
  padding: 48rpx 60rpx 0;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF7A2E 0%, #FF9A56 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 4rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 122, 46, 0.35);
  transition: all 0.2s;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(255, 122, 46, 0.25);
}

.submit-btn.disabled {
  opacity: 0.7;
}

/* ===== 底部提示 ===== */
.footer-tip {
  display: flex;
  justify-content: center;
  padding: 40rpx 0 60rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #bbb;
}