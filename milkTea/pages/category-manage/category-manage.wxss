/* 排序输入框特殊样式 */
.sort-input {
  text-align: left;
  vertical-align: middle;
  line-height: normal;
}

/* 针对数字输入框的优化 */
input[type="number"],
input[type="digit"] {
  text-align: left;
  vertical-align: middle;
}

/* 或者使用更精确的选择器 */
.form-input.sort-input {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  line-height: 1.4;
  padding: 24rpx;
}

/* 确保输入框内容垂直居中 */
.form-input {
  width: 100%;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 1rpx solid transparent;
  transition: all 0.2s;
  line-height: 1.4;  /* 添加行高 */
  height: auto;      /* 自动高度 */
  min-height: 88rpx; /* 最小高度 */
}

/* 输入框聚焦时 */
.form-input:focus {
  border-color: #ff9800;
  background: #fff;
}

/* 针对微信小程序 input 的 placeholder 样式 */
.form-input::placeholder {
  color: #ccc;
  font-size: 28rpx;
  line-height: 1.4;
}

