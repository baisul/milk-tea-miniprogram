.form-input {
  width: 100%;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 1rpx solid transparent;
  transition: all 0.2s;
}

.form-input:focus {
  border-color: #ff9800;
  background: #fff;
}

/* 选择器 */
.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  transition: all 0.2s;
}

.form-picker:active {
