.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #fff;
  border-radius: 0 0 32rpx 32rpx;
  flex-shrink: 0;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
