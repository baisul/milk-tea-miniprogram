/* pages/shop-manage/shop-manage.wxss - 店铺维护页样式 */
.shop-manage-page {
  padding: 24rpx 32rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.loading-wrap {
  padding: 120rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--primary);
  animation: pulse 0.8s ease-in-out infinite;
}

.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }

.shop-list {
  padding-bottom: 140rpx;
}

.shop-card {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx var(--shadow-color);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.shop-card-main {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.shop-top-row {
  display: flex;
  gap: 18rpx;
  align-items: center;
}

.shop-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: #f7f8fa;
}

.shop-main-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.shop-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.shop-code {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.shop-meta {
  font-size: 26rpx;
  color: var(--text-regular);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-dot {
  color: #cccccc;
}

.shop-address {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.shop-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 18rpx;
}

.action-btn {
  flex: 1;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 14rpx;
  background: #f7f8fa;
  color: #666666;
}

.action-btn:active {
  opacity: 0.85;
}

.action-btn-danger {
  background: #fff0f0;
  color: #ff4d4f;
}

.action-icon {
  font-size: 30rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 10;
}

.add-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF7A2E, #FF9A56);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 122, 46, 0.3);
}

/* ===== 弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.modal-panel {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 36rpx;
  color: #999999;
  padding: 8rpx;
}

.modal-scroll {
  flex: 1;
  overflow: auto;
  max-height: none;
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 26rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 14rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 130rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #BBBBBB;
}

.picker-active {
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

.image-upload {
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.upload-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
}

.upload-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  border: 2rpx dashed #DDDDDD;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999999;
  gap: 10rpx;
}

.upload-icon {
  font-size: 48rpx;
  line-height: 1;
}

.upload-text {
  font-size: 26rpx;
}

.upload-loading {
  position: absolute;
  bottom: 14rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  font-size: 24rpx;
  color: #666666;
}

.choose-location {
  width: 100%;
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #eeeeee;
  font-size: 26rpx;
  color: #666666;
}

.modal-footer {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
  border-top: 1rpx solid #F0F0F0;
  flex-shrink: 0;
  background: #ffffff;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border-radius: 12rpx;
}

.modal-btn-cancel {
  background: #F7F8FA;
  color: #666666;
}

.modal-btn-cancel:active {
  background: #F0F0F0;
}

.modal-btn-confirm {
  background: linear-gradient(135deg, #FF7A2E, #FF9A56);
  color: #ffffff;
}

.modal-btn-confirm:active {
  opacity: 0.9;
}

.page-bottom-space {
  height: 180rpx;
}

/* picker 内容区域 */
/* 让 picker 和其他输入框高度一致 */
/* WXSS */
.form-picker-full {
  display: block;
  width: 100%;
}

.picker-content {
  background-color: #f5f5f5;
  border-radius: 12rpx;
  height: 80rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
}

.picker-value {
  flex: 1;
  color: #333333;
  line-height: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow {
  color: #999999;
  font-size: 40rpx;
  transform: rotate(90deg);
  margin-left: 10rpx;
  width: 40rpx;
  text-align: center;
}

.label {
  display: flex;
  flex-direction: row;
  align-items: center;  /* 垂直居中 */
  justify-content: flex-start;  /* 水平靠左 */
}

.required-star {
  color: #ff4d4f;
  font-size: 28rpx;
  line-height: 1;  /* 确保垂直居中 */
  margin-right: 8rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1;
}



