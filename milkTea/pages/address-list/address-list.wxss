/* pages/address-list/address-list.wxss - 收货地址列表页样式 */

.address-list-page {
  min-height: 100vh;
  background: var(--bg-color, #F7F8FA);
  padding: 24rpx 32rpx;
  padding-bottom: 160rpx;
}

/* ============ 加载动画 ============ */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background: #FF7A2E;
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite both;
}

.loading-dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dot:nth-child(2) { animation-delay: -0.16s; }
.loading-dot:nth-child(3) { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.3); opacity: 0.3; }
  40% { transform: scale(1); opacity: 1; }
}

/* ============ 空状态 ============ */
.empty-wrap {
  padding-top: 80rpx;
}

.empty-btn {
  margin: 40rpx 64rpx 0;
  height: 88rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 122, 46, 0.35);
}

.empty-btn:active {
  opacity: 0.85;
}

.empty-btn-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #FFFFFF;
}

/* ============ 地址列表 ============ */
.address-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.address-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s, box-shadow 0.2s;
}

.address-card:active {
  transform: scale(0.985);
}

.address-card.selectable {
  border: 2rpx solid transparent;
}

.address-card.selectable:active {
  border-color: #FF7A2E;
  box-shadow: 0 4rpx 20rpx rgba(255, 122, 46, 0.15);
}

/* 默认标签 */
.default-badge {
  position: absolute;
  top: 0;
  right: 28rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 20rpx;
  border-radius: 0 0 12rpx 12rpx;
}

/* 收件人信息 */
.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
  gap: 8rpx;
}

.address-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary, #333);
}

.address-gender {
  font-size: 24rpx;
  color: var(--text-regular, #666);
}

.address-phone {
  font-size: 28rpx;
  color: var(--text-regular, #666);
  margin-left: 8rpx;
}

/* 标签颜色 */
.address-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
  margin-left: 4rpx;
}

.address-tag.home {
  background: #E8F5E9;
  color: #4CAF50;
}

.address-tag.company {
  background: #FFF5ED;
  color: #FF7A2E;
}

.address-tag.school {
  background: #E3F2FD;
  color: #2196F3;
}

.address-tag.other {
  background: #F5F5F5;
  color: #999;
}

/* 地址详情 */
.address-detail {
  font-size: 26rpx;
  color: var(--text-secondary, #999);
  line-height: 1.6;
  display: block;
  padding-right: 60rpx;
}

/* 操作按钮 */
.address-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 32rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-color, #EEEEEE);
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.action-item:active {
  opacity: 0.7;
}

.action-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid var(--border-color, #DDD);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #FFFFFF;
  transition: all 0.2s;
}

.action-check.checked {
  background: #FF7A2E;
  border-color: #FF7A2E;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-secondary, #999);
}

.action-danger .action-text {
  color: var(--danger-color, #FF4D4F);
}

.action-danger .action-icon-text {
  color: var(--danger-color, #FF4D4F);
}

.action-icon-text {
  font-size: 28rpx;
  color: var(--text-secondary, #999);
}

/* ============ 底部按钮 ============ */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.add-btn {
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  box-shadow: 0 4rpx 16rpx rgba(255, 122, 46, 0.35);
  transition: opacity 0.2s;
}

.add-btn:active {
  opacity: 0.85;
}

/* ============ 动画 ============ */
.fade-in {
  animation: fadeIn 0.35s ease-out both;
}

.fade-in:nth-child(2) { animation-delay: 0.08s; }
.fade-in:nth-child(3) { animation-delay: 0.16s; }
.fade-in:nth-child(4) { animation-delay: 0.24s; }
.fade-in:nth-child(5) { animation-delay: 0.32s; }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.page-bottom-space {
  height: 60rpx;
}
