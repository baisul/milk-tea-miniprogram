/* pages/cardlist/cardlist.wxss */
.cart-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  position: relative;
  overflow: visible;  /* 确保不被裁剪 */
}

/* 固定的顶部操作栏 */
.cart-action-bar-fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  /* 去掉 box-shadow，减少视觉重量 */
  /* box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02); */
}

/* 购物车内容区域 - 修改这里 */
.cart-content {
  padding-bottom: 120rpx;
  overflow: visible;
}

/* 加载动画 */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background-color: #FF7A2E;
  border-radius: 50%;
  animation: loading-dot 1.2s ease-in-out infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes loading-dot {
  0%, 60%, 100% {
    transform: scale(0.8);
    opacity: 0.5;
  }
  30% {
    transform: scale(1.2);
    opacity: 1;
  }
}

/* 购物车滚动区域 */
.cart-scroll {
  height: calc(100vh - 400rpx);  /* 根据实际调整 */
  width: 100%;
}

/* 店铺分组 */
.cart-group {
  margin-bottom: 20rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

/* 店铺头部 */
.shop-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.shop-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.clear-btn {
  font-size: 26rpx;
  color: #999999;
  padding: 8rpx 16rpx;
}

.clear-btn:active {
  opacity: 0.6;
}

/* 购物车列表 */
.cart-list {
  display: flex;
  flex-direction: column;
}

/* 购物车卡片 */
.cart-item {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

/* 第一个商品卡片 - 如果有额外的上边距，去掉它 */
.cart-item:first-child {
  padding-top: 24rpx;  /* 保持与店铺头部一致即可 */
}

.cart-item:last-child {
  border-bottom: none;
}

/* 复选框 */
.cart-checkbox {
  padding: 8rpx 0;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.checkbox.checked {
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-color: #FF7A2E;
}

.checkbox-icon {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 商品图片 */
.cart-item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  object-fit: cover;
}

.item-delete:active {
  opacity: 0.6;
}

.cart-item-spec {
  font-size: 24rpx;
  color: #999999;
}

.cart-item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-item-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #FF7A2E;
}

/* 数量控制 */
.cart-quantity-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: bold;
  color: #666666;
}

.fade-in {
  animation: fadeIn 0.3s ease-in;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.footer-left {
  flex: 1;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.select-all-text {
  font-size: 28rpx;
  color: #333333;
}

.footer-right {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.cart-total {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.total-label {
  font-size: 26rpx;
  color: #999999;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF7A2E;
}

.checkout-btn {
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  white-space: nowrap;
}

.checkout-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 加载更多提示 */
.load-more-tip {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}

/* 编辑弹窗 */
.edit-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-modal {
  width: 600rpx;
  max-height: 80vh;
  background-color: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
}

.edit-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.edit-modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.edit-modal-close {
  font-size: 40rpx;
  color: #999999;
  padding: 8rpx;
}

.edit-modal-body {
  padding: 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.edit-product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  margin: 0 auto 20rpx;
  display: block;
}

.edit-product-name {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 32rpx;
}

.edit-form-item {
  margin-bottom: 28rpx;
}

.edit-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.edit-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  color: #999999;
  font-size: 36rpx;
  transform: rotate(90deg);
}

.edit-quantity-control {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.edit-input {
  padding: 20rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.edit-modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.edit-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx;
  font-size: 30rpx;
}

.edit-btn.cancel {
  color: #999999;
  border-right: 1rpx solid #f0f0f0;
}

.edit-btn.confirm {
  color: #FF7A2E;
  font-weight: 500;
}

/* 可编辑的规格区域 */
.cart-item-spec.editable {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  background-color: #f5f5f5;
  border-radius: 24rpx;
  border: 1rpx solid #e8e8e8;
  cursor: pointer;
}

.cart-item-spec.editable:active {
  background-color: #e8e8e8;
}

.edit-spec-icon {
  font-size: 24rpx;
  color: #FF7A2E;
  margin-left: 8rpx;
}

/* 编辑弹窗中的规格选项 */
.edit-spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.edit-spec-item {
  padding: 16rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666666;
  border: 1rpx solid transparent;
}

.edit-spec-item.active {
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  color: #ffffff;
  border-color: #FF7A2E;
}

.spec-extra {
  font-size: 24rpx;
  margin-left: 4rpx;
}

/* 空状态样式 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  min-height: 60vh;
  box-sizing: border-box;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-subtitle {
  font-size: 28rpx;
  margin-bottom: 48rpx;
  color: #FF7A2E;
  text-decoration: underline;
}

.empty-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 44rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

.empty-btn:active {
  opacity: 0.9;
  transform: scale(0.96);
}

/* 点击态 */
.cart-spec:active {
  background: linear-gradient(135deg, #e8eef0, #e0e5e8);
  transform: scale(0.97);
  border-color: #d0d5d8;
}

.cart-emoji {
  font-size: 44rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background-color: #FF4D4F;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 24rpx;
  min-width: 32rpx;
  text-align: center;
}

/* 价格信息 */
.price-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* ========== 购物车商品项核心布局 ========== */

/* 商品主容器 - 使用 flex 布局，让数量控件自动靠右 */
.cart-item-main {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

/* 商品信息区域 - 占据剩余空间，但不影响数量控件的独立位置 */
.cart-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 商品名称和删除按钮行 */
.item-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  flex: 1;
}

.item-delete {
  font-size: 24rpx;
  color: #999999;
  padding: 8rpx;
}

/* 商品信息（规格和价格）- 独立区域 */
.cart-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* 规格胶囊 */
.cart-spec {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #f8f9fa, #f0f2f5);
  border-radius: 40rpx;
  border: 1rpx solid #e0e4e8;
  font-size: 24rpx;
  color: #555555;
  align-self: flex-start;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}

.cart-spec .edit-icon {
  font-size: 22rpx;
  color: #FF7A2E;
  margin-left: 12rpx;
  font-weight: 600;
  opacity: 0.8;
}

/* 价格 */
.cart-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF7A2E;
  margin-top: 4rpx;
}

/* 数量控制区域 - 独立于 .cart-item-info 之外，自动居右 */
.cart-quantity {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  /* 往上移动，与规格胶囊水平对齐 */
  margin-top: -102rpx;
}

/* 数量包装器 */
.quantity-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

/* 数量控制器 */
.quantity-control {
  display: flex;
  align-items: center;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  background-color: #ffffff;
  overflow: hidden;
  height: 60rpx;
  width: 180rpx;
}

/* 减号按钮 */
.qty-btn.minus {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  transition: all 0.2s ease;
}

.qty-btn.minus .qty-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #999999;
  line-height: 1;
}

/* 加号按钮 */
.qty-btn.plus {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  background-color: #ffffff;
}

.qty-btn.plus .qty-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF7A2E;
}

/* 按钮点击效果 */
.qty-btn.minus:active {
  background-color: #e0e0e0;
  transform: scale(0.95);
}

.qty-btn.plus:active {
  opacity: 0.9;
  transform: scale(0.95);
}

/* 竖线分隔符 */
.qty-divider {
  width: 1rpx;
  height: 100%;
  background-color: #e0e0e0;
  flex-shrink: 0;
}

/* 数量数字 */
.qty-num {
  min-width: 46rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0 4rpx;
}

/* ========== 顶部操作栏样式 ========== */
.cart-action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.action-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.action-right {
  display: flex;
  align-items: center;
}

.action-text {
  font-size: 28rpx;
  color: #333333;
}

.clear-all-btn {
  font-size: 28rpx;
  color: #FF7A2E;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.clear-all-btn:active {
  background-color: #f5f5f5;
  opacity: 0.8;
}

/* 强制底部结算栏显示 - 放在文件最后 */
.cart-footer {
  display: flex !important;
  visibility: visible !important;
  opacity: 1 !important;
  position: fixed !important;
  bottom: 150rpx;  /* 让出 tabBar 空间，根据实际 tabBar 高度调整 */
  left: 0 !important;
  right: 0 !important;
  background-color: #ffffff !important;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08) !important;
  border-top: 1rpx solid #f0f0f0 !important;
  padding: 20rpx 32rpx !important;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom)) !important;
  z-index: 99999 !important;
  justify-content: flex-end !important;
  align-items: center !important;
}