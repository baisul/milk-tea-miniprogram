/* pages/home/home.wxss - 首页样式 */

.home-page {
  min-height: 100vh;
  background: var(--bg-color, #F7F8FA);
  padding-bottom: 140rpx;
  position: relative;
  overflow: visible; /* 确保按钮不被裁剪 */
}

/* ============ Banner轮播 ============ */
.banner-section {
  padding: 24rpx 32rpx 0;
}

.banner-swiper {
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
}

.banner-default {
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FF7A2E, #FF9A56);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.banner-default-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.banner-default-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ============ 入口卡片 ============ */
.entry-section {
  padding: 32rpx 32rpx 0;
  display: flex;
  gap: 20rpx;
}

.entry-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
  transition: transform 0.2s;
}

.entry-card:active {
  transform: scale(0.97);
}

.entry-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.dine-in-icon {
  background: linear-gradient(135deg, #FFF5ED, #FFE8D6);
}

.delivery-icon {
  background: linear-gradient(135deg, #E8F8FF, #D6F0FF);
}

.entry-icon-text {
  font-size: 48rpx;
}

.entry-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.entry-desc {
  font-size: 22rpx;
  color: #999999;
}

.entry-arrow {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #CCCCCC;
}

/* ============ 推荐饮品 ============ */
.recommend-section {
  padding: 40rpx 0 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  font-size: 26rpx;
  color: #999999;
}

/* 加载动画 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background: #FF7A2E;
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite both;
}

.loading-dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dot:nth-child(2) { animation-delay: -0.16s; }
.loading-dot:nth-child(3) { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.3); opacity: 0.3; }
  40% { transform: scale(1); opacity: 1; }
}

/* 饮品滚动 */
.drink-scroll {
  width: 100%;
  white-space: nowrap;
  padding-left: 32rpx;
  padding-right: 16rpx;
}

.drink-scroll-inner {
  display: inline-flex;
  gap: 20rpx;
  padding-right: 32rpx;
}

.drink-item {
  display: inline-flex;
  flex-direction: column;
  width: 240rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  vertical-align: top;
  white-space: normal;
  transition: transform 0.2s;
}

.drink-item:active {
  transform: scale(0.97);
}

.drink-image {
  width: 240rpx;
  height: 200rpx;
}

.drink-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  padding: 16rpx 16rpx 4rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.drink-desc {
  font-size: 22rpx;
  color: #999999;
  padding: 0 16rpx 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.drink-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 16rpx 16rpx;
}

.drink-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF4D4F;
}

.drink-add-btn {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 48rpx;
  text-align: center;
}

.drink-add-btn:active {
  opacity: 0.85;
}

/* ============ 活动卡片 ============ */
.activity-section {
  padding: 32rpx 32rpx 0;
}

.activity-card {
  background: linear-gradient(135deg, #FFF5ED, #FFECD2);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  position: relative;
  overflow: hidden;
}

.activity-badge {
  display: inline-block;
  background: #FF7A2E;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.activity-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.activity-desc {
  display: block;
  font-size: 24rpx;
  color: #666666;
}

/* ============ 动画 ============ */
.fade-in {
  animation: fadeIn 0.4s ease-out both;
}

.content {
  height: 100vh;
  box-sizing: border-box;
  overflow-y: auto;
}

.home-content {
  padding-bottom: 160rpx;
}



/* 简洁稳定的圆形按钮 */
.ai-fab {
  position: fixed;
  bottom: 160rpx;
  left: 50%;
  margin-left: -60rpx; /* 负边距实现居中 */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  width: 160rpx;
  height: 160rpx;
  min-width: 160rpx;
  min-height: 160rpx;
  background: linear-gradient(135deg, #FF9A56, #FF7A2E);
  border-radius: 50%;
  box-shadow: 0 12rpx 28rpx rgba(255, 122, 46, 0.4);
  z-index: 100;
  transition: transform 0.2s, box-shadow 0.2s;
}

.ai-fab:active {
  transform: scale(0.94);
  box-shadow: 0 6rpx 16rpx rgba(255, 122, 46, 0.4);
}

.fab-icon {
  font-size: 48rpx;
}

.fab-text {
  font-size: 20rpx;
  font-weight: 500;
  color: white;
}

/* 呼吸动画 */
@keyframes breathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.ai-fab {
  animation: breathe 2s ease infinite;
}

.ai-fab:active {
  animation: none;
}



.fade-in:nth-child(2) { animation-delay: 0.1s; }
.fade-in:nth-child(3) { animation-delay: 0.2s; }
.fade-in:nth-child(4) { animation-delay: 0.3s; }
.fade-in:nth-child(5) { animation-delay: 0.4s; }
.fade-in:nth-child(6) { animation-delay: 0.5s; }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.page-bottom-space {
  height: 80rpx;
}

/* 测试弹窗样式 */
.test-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.test-popup {
  width: 80%;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.test-header {
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
  background: #f5f5f5;
  border-bottom: 1rpx solid #eee;
}

.test-body {
  padding: 60rpx;
  text-align: center;
}
